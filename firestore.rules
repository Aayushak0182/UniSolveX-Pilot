rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /crm_leads/{document} {
      allow read, write: if request.auth != null;
    }

    match /crm_chats/{document} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
