rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerEmail() {
      return request.auth.token.email;
    }

    function isOwnerCreate() {
      return signedIn() && request.resource.data.owner == ownerEmail();
    }

    function isOwnerExisting() {
      return signedIn() && resource.data.owner == ownerEmail();
    }

    match /crm_leads/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_chats/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_campaigns/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_templates/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_accounts/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_groups/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /crm_telegram_dispatches/{document} {
      allow create: if isOwnerCreate();
      allow read, update, delete: if isOwnerExisting();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
